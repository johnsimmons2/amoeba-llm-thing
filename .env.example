# HuggingFace token — required for gated/private model downloads
# Get yours at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CivitAI API key — required for gated model downloads
# Get yours at https://civitai.com/user/account (API Keys section)
# CIVITAI_API_KEY=

# Server
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=INFO

# Ollama
# OLLAMA_URL=http://localhost:11434

# Oracle (cloud escalation)
# ORACLE_API_URL=
# ORACLE_API_KEY=
# ORACLE_MODEL=
# ORACLE_DAILY_LIMIT=20
